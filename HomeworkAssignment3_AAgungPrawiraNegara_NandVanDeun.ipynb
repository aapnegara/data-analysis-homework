  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "print(myFit31.ci_report(sigmas=[2], with_offset=False))\n",
    "print(myFit32.ci_report(sigmas=[2], with_offset=False))\n",
    "print(myFit33.ci_report(sigmas=[2], with_offset=False))"
   ],
